# =============================================================================
# VIM — Configurazione locale (NON commitare il file .env reale)
#
# Uso:
#   1. cp .env.example .env
#   2. Inserisci i valori reali sotto
#   3. npm run build:monolith   # legge .env e inietta i valori
#
# Il file .env è gitignored. Solo .env.example finisce in repo.
# =============================================================================

# Token API KoboToolbox (PRIVATO)
# Recuperabile da: https://eu.kobotoolbox.org → Account → Security → API Token
# In Enketo Express il token NON serve qui (è gestito server-side).
VIM_KOBO_TOKEN=il_tuo_token_kobo_qui

# UID del form su KoboToolbox
# Visibile nella URL del form: https://eu.kobotoolbox.org/#/forms/<UID>/
VIM_KOBO_UID=il_tuo_form_uid_qui

# URL base del server KoboToolbox
# Default: server europeo
VIM_KOBO_BASE=https://eu.kobotoolbox.org

# Codice condiviso per il login dei tester beta (PROVVISORIO, non è vera sicurezza)
# Iniettato nel monolite a build time. Cambialo prima della distribuzione ai tester.
VIM_TESTER_CODE=vim-beta-2026
