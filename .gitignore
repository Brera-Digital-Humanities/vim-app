# =============================================================================
# Dipendenze npm (rigenerabili con `npm install`)
# =============================================================================
node_modules/
package-lock.json

# =============================================================================
# Artefatti generati dallo script di build (rigenerabili con `npm run build`)
# - dist/          = PWA single-file (app, full-screen) + manifest/service-worker/icons
# - demo-desktop/  = demo single-file con skin telefono
# - i .bak storici contengono TOKEN compromesso — non committare
# =============================================================================
/dist/
/demo-desktop/
*.bak
*.orig

# File temporanei sass / editor
.sass-cache/
*.css.map
*.swp
*.swo
.DS_Store
.vscode/
.idea/
.claude/

# Log
*.log
npm-debug.log*
